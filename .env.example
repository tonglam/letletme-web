# --- Existing -----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3000
GRAPHQL_ENDPOINT=http://127.0.0.1:4000/graphql
TOURNAMENT_API_BASE_URL=http://127.0.0.1:4001

# --- Better Auth + Drizzle (new) ---------------------------------------
# Postgres connection string. Auth tables live in the `auth` schema, which
# is created by `drizzle/0000_init_schema.sql` before the Better Auth
# tables are migrated.
DATABASE_URL=postgres://user:password@127.0.0.1:5432/letletme

# 32+ byte random string. Generate with `openssl rand -base64 32`.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials).
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# WeChat Open Platform website application (https://open.weixin.qq.com).
# Authorization callback domain must match BETTER_AUTH_URL host.
WECHAT_CLIENT_ID=
WECHAT_CLIENT_SECRET=

# 32+ byte random string shared with the GraphQL backend so it can verify
# the X-User-Context envelope. Generate with `openssl rand -base64 32`.
BACKEND_PROXY_SECRET=

# SMTP (verification + password reset). In dev, the mailer logs to stdout
# when these are unset.
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@letletme.top
