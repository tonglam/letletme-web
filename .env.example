# --- Existing -----------------------------------------------------------
GRAPHQL_ENDPOINT=http://127.0.0.1:4000/graphql
TOURNAMENT_API_BASE_URL=http://127.0.0.1:4001
# Server-only plaintext credential. Its SHA-256 digest belongs in Data's
# DATA_API_KEY_HASHES. Never prefix this variable with NEXT_PUBLIC_.
TOURNAMENT_API_KEY=

# --- Better Auth + Drizzle (new) ---------------------------------------
# Postgres connection string. Auth tables live in the `bauth` schema, which
# is created by the guarded Web migration runner before the Better Auth tables
# are migrated.
DATABASE_URL=postgres://user:password@127.0.0.1:5432/letletme
# Direct, non-transaction-pooler connection used only by migration commands.
DIRECT_DATABASE_URL=postgres://user:password@127.0.0.1:5432/letletme

# 32+ byte random string. Generate with `openssl rand -base64 32`.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials).
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# WeChat Mini Program login (wx.login -> code2Session).
WECHAT_MINIPROGRAM_APP_ID=
WECHAT_MINIPROGRAM_APP_SECRET=

# Set true only after migrating `drizzle/0001_miniprogram_account.sql` (live Supabase omits those tables today).
MINIPROGRAM_ACCOUNT_STORAGE=

# 32+ byte random string shared with the GraphQL backend so it can verify
# the X-User-Context envelope. Generate with `openssl rand -base64 32`.
BACKEND_PROXY_SECRET=

# Resend (verification, password reset, and Mini Program linking codes).
RESEND_API_KEY=
MAIL_FROM=no-reply@letletme.top
